<section class="quiz" style="font-family: 'Lato', 'Helvetica Neue', Arial, sans-serif;">
  <p>{{ quiz.intro | e }}</p>
  <blockquote>{{ quiz.key_quote | e }}</blockquote>
  <h2 style="margin-top: 1.5rem; margin-bottom: 0.75rem;">Knowledge Check</h2>

  {% for q in quiz.mc_questions %}
  <fieldset style="margin-bottom:1.25rem;">
    <legend>{{ q.question | e }}</legend>

    {% for c in q.choices %}
    <input
      type="button"
      class="btn btn-light btn-block"
      value="{{ (c.label ~ '. ' ~ c.text) | replace('\"', '″') | e }}"
      data-label="{{ (c.label ~ '. ' ~ c.text) | replace('\"', '″') | e }}"
      onclick="
        // prevent repeated prefixing on multiple clicks
        if (this.dataset.answered === '1') return;
        this.dataset.answered = '1';

        var ok = {{ 'true' if c.correct else 'false' }};
        this.style.backgroundColor = ok ? '#008000' : '#dc143c';
        this.style.color = 'white';

        // always format from the pristine label we stored
        var base = this.dataset.label || this.value;
        this.value = (ok ? 'Correct: ' : 'Incorrect: ') + base;
      "
    >
    {% endfor %}

    <!-- Feedback: always present; user can expand/collapse at any time -->
    <details class="feedback" style="margin-top:6px;">
      <summary style="cursor:pointer; font-size:1.05em; font-weight:600; margin:0;">Feedback</summary>
      <div class="feedback-body" style="margin-top:6px;">
        {{ q.feedback | e }}
      </div>
    </details>
  </fieldset>
  {% endfor %}

  {% for t in quiz.tf_questions %}
  <fieldset style="margin-bottom:1.25rem;">
    <legend>{{ t.statement | e }}</legend>

    <input
      type="button"
      class="btn btn-light btn-block"
      value="True"
      data-label="True"
      onclick="
        if (this.dataset.answered === '1') return;
        this.dataset.answered = '1';

        var ok = {{ 'true' if t.answer else 'false' }};
        this.style.backgroundColor = ok ? '#008000' : '#dc143c';
        this.style.color = 'white';

        var base = this.dataset.label || this.value;
        this.value = ok ? 'Correct: ' + base : 'Incorrect: ' + base;
      "
    >

    <input
      type="button"
      class="btn btn-light btn-block"
      value="False"
      data-label="False"
      onclick="
        if (this.dataset.answered === '1') return;
        this.dataset.answered = '1';

        var ok = {{ 'false' if t.answer else 'true' }};
        this.style.backgroundColor = ok ? '#008000' : '#dc143c';
        this.style.color = 'white';

        var base = this.dataset.label || this.value;
        this.value = ok ? 'Correct: ' + base : 'Incorrect: ' + base;
      "
    >

    <!-- Feedback: always present; user can expand/collapse at any time -->
    <details class="feedback" style="margin-top:6px;">
      <summary style="cursor:pointer; font-size:1.05em; font-weight:600; margin:0;">Feedback</summary>
      <div class="feedback-body" style="margin-top:6px;">
        {{ t.feedback | e }}
      </div>
    </details>
  </fieldset>
  {% endfor %}
</section>
