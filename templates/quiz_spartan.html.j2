<section class="quiz">
  {# -------- Introduction (optional) -------- #}
  {% if include_intro and quiz.intro %}
    <h2>Introduction</h2>
    <p>{{ quiz.intro | e }}</p>
  {% endif %}

  <p>[embed video]</p>

  {# Optional transcript accordion, displayed under the embed video line #}
  {% if include_transcript and transcript %}
    <details class="transcript" style="margin-top:1rem; margin-bottom:1.25rem;">
      <summary style="cursor:pointer; font-weight:400; margin-bottom:0.5rem;">
        Transcript
      </summary>
      <div
        style="
          max-height:12rem;
          overflow-y:auto;
          padding:0.75rem;
          border:1px solid #dddddd;
          border-radius:4px;
          background-color:#fafafa;
          white-space:pre-wrap;
        "
      >
        {{ transcript | e }}
      </div>
    </details>
  {% endif %}

  {% if quiz.key_quotes %}
    <h2>Quote</h2>
    {% for quote in quiz.key_quotes[:5] %}
      <blockquote style="margin:0 0 1.75rem 0; font-style:normal; font-weight:400;">
        {{ quote | e }}
      </blockquote>
    {% endfor %}
  {% endif %}

  <h2>Knowledge Check</h2>
  <p>Knowledge Checks are not recorded. Refresh the page to try again.</p>

  {% set ns = namespace(qnum=1) %}

  {% for q in quiz.mc_questions %}
  <fieldset style="margin-bottom:1.5rem;">
    <legend style="margin-bottom:0.25rem; font-weight:400; font-family:inherit;">
      Q{{ ns.qnum }}. {{ q.question | e }}
    </legend>

    {% for c in q.choices %}
    <input
      type="button"
      class="btn btn-light btn-block"
      value="{{ (c.label ~ '. ' ~ c.text) | replace('\"', '″') | e }}"
      data-label="{{ (c.label ~ '. ' ~ c.text) | replace('\"', '″') | e }}"
      onclick="
        if (this.dataset.answered === '1') return;
        this.dataset.answered = '1';

        var ok = {{ 'true' if c.correct else 'false' }};
        this.style.backgroundColor = ok ? '#008000' : '#dc143c';
        this.style.color = 'white';

        var base = this.dataset.label || this.value;
        this.value = (ok ? 'Correct: ' : 'Incorrect: ') + base;
      "
    >
    {% endfor %}

    <details class="feedback" style="margin-top:6px;">
      <summary style="cursor:pointer; font-weight:400; margin:0;">Feedback</summary>
      <div class="feedback-body" style="margin-top:6px;">
        {{ q.feedback | e }}
      </div>
    </details>
  </fieldset>
  {% set ns.qnum = ns.qnum + 1 %}
  {% endfor %}

  {% for t in quiz.tf_questions %}
  <fieldset style="margin-bottom:1.5rem;">
    <legend style="margin-bottom:0.25rem; font-weight:400; font-family:inherit;">
      Q{{ ns.qnum }}. {{ t.statement | e }}
    </legend>

    <input
      type="button"
      class="btn btn-light btn-block"
      value="True"
      data-label="True"
      onclick="
        if (this.dataset.answered === '1') return;
        this.dataset.answered = '1';

        var ok = {{ 'true' if t.answer else 'false' }};
        this.style.backgroundColor = ok ? '#008000' : '#dc143c';
        this.style.color = 'white';

        var base = this.dataset.label || this.value;
        this.value = ok ? 'Correct: ' + base : 'Incorrect: ' + base;
      "
    >

    <input
      type="button"
      class="btn btn-light btn-block"
      value="False"
      data-label="False"
      onclick="
        if (this.dataset.answered === '1') return;
        this.dataset.answered = '1';

        var ok = {{ 'false' if t.answer else 'true' }};
        this.style.backgroundColor = ok ? '#008000' : '#dc143c';
        this.style.color = 'white';

        var base = this.dataset.label || this.value;
        this.value = ok ? 'Correct: ' + base : 'Incorrect: ' + base;
      "
    >

    <details class="feedback" style="margin-top:6px;">
      <summary style="cursor:pointer; font-weight:400; margin:0;">Feedback</summary>
      <div class="feedback-body" style="margin-top:6px;">
        {{ t.feedback | e }}
      </div>
    </details>
  </fieldset>
  {% set ns.qnum = ns.qnum + 1 %}
  {% endfor %}
</section>
<p>&nbsp;</p>